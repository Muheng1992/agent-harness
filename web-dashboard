<script>
/* ═══════════════════════════════════════
   全域狀態與工具函式
   ═══════════════════════════════════════ */
const BASE = window.location.origin;
let allTasks = [];
let allAuditLogs = [];
let autoRefreshInterval = null;
let expandedTaskId = null;
let selectedPromptTaskId = null;

function api(path) {
  return fetch(BASE + path).then(r => {
    if (!r.ok) throw new Error(r.status + ' ' + r.statusText);
    return r.json();
  });
}

function esc(s) {
  if (s == null) return '';
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

function truncate(s, n) {
  if (!s) return '';
  return s.length > n ? s.slice(0, n) + '…' : s;
}

function renderMarkdown(text) {
  if (!text) return '';
  var s = esc(text);
  var BT = String.fromCharCode(96);
  var fence = BT + BT + BT;
  // code blocks
  var cbRe = new RegExp(fence + '(\\\\w*)\\n([\\\\s\\\\S]*?)' + fence, 'g');
  s = s.replace(cbRe, function(_, lang, code) {
    return '<pre class="md-code-block"><code>' + code + '</code></pre>';
  });
  // inline code
  var icRe = new RegExp(BT + '([^' + BT + ']+)' + BT, 'g');
  s = s.replace(icRe, '<code class="md-inline-code">$1</code>');
  // headers
  s = s.replace(/^#### (.+)$/gm, '<h6 class="md-h">$1</h6>');
  s = s.replace(/^### (.+)$/gm, '<h5 class="md-h">$1</h5>');
  s = s.replace(/^## (.+)$/gm, '<h4 class="md-h">$1</h4>');
  s = s.replace(/^# (.+)$/gm, '<h3 class="md-h">$1</h3>');
  // bold
  s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  // horizontal rule
  s = s.replace(/^---$/gm, '<hr class="md-hr">');
  // unordered list items
  s = s.replace(/^[\s]*[-] (.+)$/gm, '<li class="md-li">$1</li>');
  // ordered list items
  s = s.replace(/^[\s]*\d+\. (.+)$/gm, '<li class="md-li md-ol">$1</li>');
  // paragraphs (double newline)
  s = s.replace(new RegExp('\\n\\n', 'g'), '</p><p class="md-p">');
  // single newline to line break
  s = s.replace(new RegExp('\\n', 'g'), '<br>');
  return '<div class="md-content"><p class="md-p">' + s + '</p></div>';
}

function parseClaudeOutput(raw) {
  if (!raw) return { summary: '', detail: '' };
  try {
    var obj = JSON.parse(raw);
    return {
      summary: obj.result || '',
      detail: raw,
      duration_ms: obj.duration_ms,
      num_turns: obj.num_turns,
      cost: obj.total_cost_usd,
      is_error: obj.is_error
    };
  } catch (e) {
    return { summary: raw, detail: '' };
  }
}

function fmtTime(t) {
  if (!t) return '—';
  const d = new Date(t);
  if (isNaN(d)) return t;
  return d.toLocaleString('zh-TW', { hour12: false });
}

function statusBadge(status) {
  const cls = (status || 'pending').toLowerCase();
  return '<span class="status-badge ' + esc(cls) + '">' + esc(status) + '</span>';
}

function eventBadge(type) {
  const known = ['task_created','task_started','task_completed','task_failed','task_escalated','run_started','run_completed'];
  const cls = known.includes(type) ? type : 'default';
  return '<span class="event-badge ' + cls + '">' + esc(type) + '</span>';
}

function showLoading(id, show) { document.getElementById(id).style.display = show ? 'flex' : 'none'; }
function showEmpty(id, show)   { document.getElementById(id).style.display = show ? 'block' : 'none'; }

/* ═══════════════════════════════════════
   Tab 切換
   ═══════════════════════════════════════ */
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    // 切換時觸發資料載入
    if (btn.dataset.tab === 'graph') loadGraph();
    if (btn.dataset.tab === 'prompts') loadPromptTasks();
    if (btn.dataset.tab === 'audit') loadAudit();
  });
});

/* ═══════════════════════════════════════
   Tab 1: 任務總覽
   ═══════════════════════════════════════ */
async function loadTasks() {
  showLoading('tasksLoading', true);
  showEmpty('tasksEmpty', false);
  try {
    const data = await api('/api/tasks');
    allTasks = Array.isArray(data) ? data : (data.tasks || []);
    populateFilters();
    renderStats();
    renderTaskTable();
  } catch (e) {
    console.error('載入任務失敗:', e);
    allTasks = [];
  }
  showLoading('tasksLoading', false);
  if (allTasks.length === 0) showEmpty('tasksEmpty', true);
}

function populateFilters() {
  const projects = [...new Set(allTasks.map(t => t.project).filter(Boolean))];
  const statuses = [...new Set(allTasks.map(t => t.status).filter(Boolean))];
  const roles    = [...new Set(allTasks.map(t => t.role).filter(Boolean))];
  fillSelect('filterProject', projects, '所有專案');
  fillSelect('filterStatus', statuses, '所有狀態');
  fillSelect('filterRole', roles, '所有角色');
}

function fillSelect(id, items, defaultLabel) {
  const el = document.getElementById(id);
  const val = el.value;
  el.innerHTML = '<option value="">' + defaultLabel + '</option>';
  items.sort().forEach(item => {
    el.innerHTML += '<option value="' + esc(item) + '">' + esc(item) + '</option>';
  });
  el.value = val;
}

function getFilteredTasks() {
  const p = document.getElementById('filterProject').value;
  const s = document.getElementById('filterStatus').value;
  const r = document.getElementById('filterRole').value;
  return allTasks.filter(t =>
    (!p || t.project === p) &&
    (!s || t.status === s) &&
    (!r || t.role === r)
  );
}

function renderStats() {
  const counts = { pending: 0, running: 0, pass: 0, fail: 0, escalated: 0, blocked: 0 };
  allTasks.forEach(t => {
    const s = (t.status || '').toLowerCase();
    if (s in counts) counts[s]++;
  });
  const total = allTasks.length;
  const passRate = total > 0 ? ((counts.pass / total) * 100).toFixed(1) + '%' : '—';

  document.getElementById('statsRow').innerHTML =
    Object.entries(counts).map(([k, v]) =>
      '<div class="stat-card ' + k + '"><div class="value">' + v + '</div><div class="label">' + k + '</div></div>'
    ).join('') +
    '<div class="stat-card rate"><div class="value">' + passRate + '</div><div class="label">Pass Rate</div></div>';
}

function renderTaskTable() {
  const tasks = getFilteredTasks();
  const tbody = document.getElementById('tasksBody');
  tbody.innerHTML = '';

  tasks.forEach(t => {
    const tr = document.createElement('tr');
    tr.innerHTML =
      '<td>' + esc(t.id || t.task_id) + '</td>' +
      '<td>' + esc(t.project) + '</td>' +
      '<td class="truncate" title="' + esc(t.goal) + '">' + esc(truncate(t.goal, 60)) + '</td>' +
      '<td>' + statusBadge(t.status) + '</td>' +
      '<td>' + esc(t.role || '—') + '</td>' +
      '<td>' + esc((t.attempt_count || 0) + '/' + (t.max_attempts || '—')) + '</td>' +
      '<td>' + esc(t.spawned_by || '—') + '</td>' +
      '<td>' + fmtTime(t.updated_at) + '</td>';
    tr.addEventListener('click', () => toggleTaskDetail(t, tr));
    tbody.appendChild(tr);

    // 恢復展開狀態
    const tid = t.id || t.task_id;
    if (expandedTaskId === tid) {
      const detailTr = document.createElement('tr');
      detailTr.innerHTML = '<td colspan="8">' + buildDetailPanel(t) + '</td>';
      detailTr.classList.add('detail-row');
      tbody.appendChild(detailTr);
    }
  });
}

function toggleTaskDetail(task, tr) {
  const tid = task.id || task.task_id;
  if (expandedTaskId === tid) {
    expandedTaskId = null;
  } else {
    expandedTaskId = tid;
  }
  renderTaskTable();
}

function buildDetailPanel(t) {
  const tid = t.id || t.task_id;
  return '<div class="detail-panel">' +
    '<div class="detail-row"><div class="detail-label">完整目標</div><div class="detail-value">' + esc(t.goal) + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">depends_on</div><div class="detail-value">' + esc(JSON.stringify(t.depends_on || [])) + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">touches</div><div class="detail-value">' + esc(JSON.stringify(t.touches || [])) + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">error_class</div><div class="detail-value">' + esc(t.error_class || '—') + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">last_error</div><div class="detail-value"><pre>' + esc(t.last_error || '—') + '</pre></div></div>' +
    '<button class="btn" onclick="goToRuns(\\'' + esc(tid) + '\\')">查看 Runs</button>' +
  '</div>';
}

function goToRuns(taskId) {
  // 跳到 Prompts tab 並選中該任務
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.querySelector('[data-tab="prompts"]').classList.add('active');
  document.getElementById('tab-prompts').classList.add('active');
  selectedPromptTaskId = taskId;
  loadPromptTasks().then(() => loadRuns(taskId));
}

// 篩選事件
['filterProject', 'filterStatus', 'filterRole'].forEach(id => {
  document.getElementById(id).addEventListener('change', renderTaskTable);
});

/* ═══════════════════════════════════════
   Tab 2: Agent 分派鏈 (Graph)
   ═══════════════════════════════════════ */
async function loadGraph() {
  showLoading('graphLoading', true);
  showEmpty('graphEmpty', false);
  document.getElementById('graphContainer').innerHTML = '';
  document.getElementById('graphNodeDetail').style.display = 'none';

  let graphData;
  try {
    graphData = await api('/api/graph');
  } catch (e) {
    // fallback：從 allTasks 建構圖
    if (allTasks.length === 0) {
      try { await loadTasks(); } catch (_) {}
    }
    graphData = { nodes: allTasks, edges: [] };
  }

  showLoading('graphLoading', false);

  const nodes = graphData.nodes || graphData.tasks || graphData || [];
  if (!Array.isArray(nodes) || nodes.length === 0) {
    showEmpty('graphEmpty', true);
    return;
  }

  // 用 edges 建構 DAG，按 project 分組，拓撲排序成層
  const edges = graphData.edges || [];
  const nodeMap = {};
  nodes.forEach(n => { nodeMap[n.id || n.task_id] = n; });

  // 按 project 分組
  const projectGroups = {};
  nodes.forEach(n => {
    const proj = n.project || 'unknown';
    if (!projectGroups[proj]) projectGroups[proj] = { nodes: [], edges: [] };
    projectGroups[proj].nodes.push(n);
  });
  edges.forEach(e => {
    const toNode = nodeMap[e.to];
    if (toNode) {
      const proj = toNode.project || 'unknown';
      if (projectGroups[proj]) projectGroups[proj].edges.push(e);
    }
  });

  const container = document.getElementById('graphContainer');

  Object.keys(projectGroups).sort().forEach(proj => {
    const group = projectGroups[proj];
    const groupDiv = document.createElement('div');
    groupDiv.className = 'graph-project-group';
    groupDiv.innerHTML = '<div class="graph-project-title">' + esc(proj) + ' (' + group.nodes.length + ' tasks)</div>';

    const dagDiv = document.createElement('div');
    dagDiv.className = 'dag-canvas';
    dagDiv.style.position = 'relative';

    // 拓撲排序成層
    const layers = topoSort(group.nodes, group.edges);

    // 渲染每一層
    const cardPositions = {};
    layers.forEach((layer, layerIdx) => {
      const layerDiv = document.createElement('div');
      layerDiv.className = 'dag-layer';
      layerDiv.innerHTML = '<div class="dag-layer-label">Layer ' + layerIdx + '</div>';

      layer.forEach(n => {
        const card = document.createElement('div');
        const status = (n.status || 'pending').toLowerCase();
        card.className = 'node-card status-' + status;
        card.setAttribute('data-node-id', n.id);
        card.innerHTML =
          '<div class="node-id">' + esc(n.id) + '</div>' +
          statusBadge(n.status) +
          '<div class="node-role">' + esc(n.role || '') + '</div>' +
          '<div class="node-goal">' + esc(truncate(n.goal, 25)) + '</div>';
        card.addEventListener('click', function(e) {
          e.stopPropagation();
          document.querySelectorAll('.node-card.highlighted').forEach(function(c) { c.classList.remove('highlighted'); });
          card.classList.add('highlighted');
          showGraphNodeDetail(n);
        });
        card.addEventListener('mouseenter', function() { highlightEdges(dagDiv, n.id, true); });
        card.addEventListener('mouseleave', function() { highlightEdges(dagDiv, n.id, false); });
        layerDiv.appendChild(card);
      });

      dagDiv.appendChild(layerDiv);
    });

    groupDiv.appendChild(dagDiv);
    container.appendChild(groupDiv);

    // 渲染 SVG 連線（等 DOM layout 完成）
    requestAnimationFrame(function() {
      drawEdges(dagDiv, group.edges);
    });
  });
}

function topoSort(nodes, edges) {
  var idSet = {};
  nodes.forEach(function(n) { idSet[n.id] = n; });
  var inDegree = {};
  var children = {};
  nodes.forEach(function(n) { inDegree[n.id] = 0; children[n.id] = []; });
  edges.forEach(function(e) {
    if (idSet[e.from] && idSet[e.to]) {
      inDegree[e.to] = (inDegree[e.to] || 0) + 1;
      children[e.from] = children[e.from] || [];
      children[e.from].push(e.to);
    }
  });

  var layers = [];
  var queue = [];
  nodes.forEach(function(n) { if (inDegree[n.id] === 0) queue.push(n); });

  while (queue.length > 0) {
    layers.push(queue.slice());
    var next = [];
    queue.forEach(function(n) {
      (children[n.id] || []).forEach(function(cid) {
        inDegree[cid]--;
        if (inDegree[cid] === 0 && idSet[cid]) next.push(idSet[cid]);
      });
    });
    queue = next;
  }

  // 處理可能的環（不應該發生，但安全起見）
  nodes.forEach(function(n) {
    var found = false;
    layers.forEach(function(l) { l.forEach(function(ln) { if (ln.id === n.id) found = true; }); });
    if (!found) {
      if (layers.length === 0) layers.push([]);
      layers[layers.length - 1].push(n);
    }
  });

  return layers;
}

function drawEdges(dagDiv, edges) {
  var svg = dagDiv.querySelector('svg');
  if (svg) svg.remove();

  var rect = dagDiv.getBoundingClientRect();
  svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  svg.setAttribute('width', dagDiv.scrollWidth);
  svg.setAttribute('height', dagDiv.scrollHeight);
  svg.style.position = 'absolute';
  svg.style.top = '0';
  svg.style.left = '0';
  svg.style.pointerEvents = 'none';
  svg.style.zIndex = '1';

  // 箭頭 marker
  var defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
  var marker = document.createElementNS('http://www.w3.org/2000/svg', 'marker');
  marker.setAttribute('id', 'arrowhead');
  marker.setAttribute('markerWidth', '8');
  marker.setAttribute('markerHeight', '6');
  marker.setAttribute('refX', '8');
  marker.setAttribute('refY', '3');
  marker.setAttribute('orient', 'auto');
  var polygon = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
  polygon.setAttribute('points', '0 0, 8 3, 0 6');
  polygon.setAttribute('fill', '#4a5568');
  marker.appendChild(polygon);
  defs.appendChild(marker);
  svg.appendChild(defs);

  edges.forEach(function(e) {
    var fromCard = dagDiv.querySelector('[data-node-id="' + e.from + '"]');
    var toCard = dagDiv.querySelector('[data-node-id="' + e.to + '"]');
    if (!fromCard || !toCard) return;

    var dagRect = dagDiv.getBoundingClientRect();
    var fromRect = fromCard.getBoundingClientRect();
    var toRect = toCard.getBoundingClientRect();

    var x1 = fromRect.left + fromRect.width / 2 - dagRect.left;
    var y1 = fromRect.bottom - dagRect.top;
    var x2 = toRect.left + toRect.width / 2 - dagRect.left;
    var y2 = toRect.top - dagRect.top;

    var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    var midY = (y1 + y2) / 2;
    var d = 'M ' + x1 + ' ' + y1 + ' C ' + x1 + ' ' + midY + ', ' + x2 + ' ' + midY + ', ' + x2 + ' ' + y2;
    path.setAttribute('d', d);
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke', '#4a5568');
    path.setAttribute('stroke-width', '2');
    path.setAttribute('marker-end', 'url(#arrowhead)');
    path.setAttribute('data-from', e.from);
    path.setAttribute('data-to', e.to);
    path.classList.add('dag-edge');
    svg.appendChild(path);
  });

  dagDiv.insertBefore(svg, dagDiv.firstChild);
}

function highlightEdges(dagDiv, nodeId, on) {
  var svg = dagDiv.querySelector('svg');
  if (!svg) return;
  svg.querySelectorAll('.dag-edge').forEach(function(path) {
    var from = path.getAttribute('data-from');
    var to = path.getAttribute('data-to');
    if (from === nodeId || to === nodeId) {
      path.setAttribute('stroke', on ? '#00d2d3' : '#4a5568');
      path.setAttribute('stroke-width', on ? '3' : '2');
    }
  });
}

function showGraphNodeDetail(node) {
  const el = document.getElementById('graphNodeDetail');
  el.style.display = 'block';
  el.innerHTML =
    '<h3 style="margin-bottom:12px">' + esc(node.id || node.task_id) + ' ' + statusBadge(node.status) + '</h3>' +
    '<div class="detail-row"><div class="detail-label">目標</div><div class="detail-value">' + esc(node.goal) + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">角色</div><div class="detail-value">' + esc(node.role || '—') + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">派生自</div><div class="detail-value">' + esc(node.spawned_by || '—') + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">depends_on</div><div class="detail-value">' + esc(JSON.stringify(node.depends_on || [])) + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">error_class</div><div class="detail-value">' + esc(node.error_class || '—') + '</div></div>' +
    '<div class="detail-row"><div class="detail-label">last_error</div><div class="detail-value"><pre>' + esc(node.last_error || '—') + '</pre></div></div>';
  el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

/* ═══════════════════════════════════════
   Tab 3: Prompt 檢視器
   ═══════════════════════════════════════ */
let promptRunsCache = {};

async function loadPromptTasks() {
  if (allTasks.length === 0) {
    try { await loadTasks(); } catch (_) {}
  }

  const listEl = document.getElementById('promptTaskList');
  listEl.innerHTML = '';

  // 顯示有 runs 的任務（attempt_count > 0）或全部
  const tasks = allTasks.filter(t => (t.attempt_count || 0) > 0 || allTasks.length < 50);
  if (tasks.length === 0) {
    listEl.innerHTML = '<div class="empty-state"><div class="empty-text">無可用任務</div></div>';
    return;
  }

  tasks.forEach(t => {
    const tid = t.id || t.task_id;
    const item = document.createElement('div');
    item.className = 'sidebar-item' + (selectedPromptTaskId === tid ? ' active' : '');
    item.innerHTML =
      '<div class="item-id">' + esc(tid) + '</div>' +
      '<div>' + esc(truncate(t.goal, 40)) + '</div>' +
      '<div>' + statusBadge(t.status) + '</div>';
    item.addEventListener('click', () => {
      selectedPromptTaskId = tid;
      document.querySelectorAll('.prompt-sidebar .sidebar-item').forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      loadRuns(tid);
    });
    listEl.appendChild(item);
  });
}

async function loadRuns(taskId) {
  const main = document.getElementById('promptMain');
  main.innerHTML = '<div class="loading-overlay"><div class="spinner"></div> 載入 Runs…</div>';

  try {
    const data = await api('/api/tasks/' + encodeURIComponent(taskId) + '/runs');
    const runs = Array.isArray(data) ? data : (data.runs || []);
    promptRunsCache[taskId] = runs;
    renderRuns(runs, taskId);
  } catch (e) {
    main.innerHTML = '<div class="empty-state"><div class="empty-text">載入失敗：' + esc(e.message) + '</div></div>';
  }
}

function renderRuns(runs, taskId) {
  const main = document.getElementById('promptMain');
  const searchTerm = document.getElementById('promptSearch').value.toLowerCase();

  if (runs.length === 0) {
    main.innerHTML = '<div class="empty-state"><div class="empty-text">此任務尚無執行記錄。</div></div>';
    return;
  }

  let html = '<h3 style="margin-bottom:16px">任務 ' + esc(taskId) + ' — ' + runs.length + ' 次執行</h3>';

  runs.forEach((run, i) => {
    const matchesSearch = !searchTerm ||
      (run.prompt_text || '').toLowerCase().includes(searchTerm) ||
      (run.claude_output || '').toLowerCase().includes(searchTerm) ||
      (run.verify_output || '').toLowerCase().includes(searchTerm);

    if (!matchesSearch) return;

    const attempt = run.attempt || (i + 1);
    const duration = run.duration ? run.duration + 's' : '—';
    const time = fmtTime(run.created_at || run.started_at);

    html += '<div class="run-card">' +
      '<div class="run-header" onclick="toggleRunBody(this)">' +
        '<div>Attempt #' + attempt + '  ' + statusBadge(run.status) + '  <span style="color:var(--text-dim);font-size:12px">' + duration + '</span></div>' +
        '<div style="display:flex;align-items:center;gap:8px">' +
          '<span style="color:var(--text-dim);font-size:12px">' + time + '</span>' +
