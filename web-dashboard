# ── 路徑設定 ──────────────────────────────────────────────

def _resolve_db_path() -> str:
    """優先順序：環境變數 > ~/.agent-harness/db > 腳本同層目錄/db"""
    env = os.environ.get("AGENT_DB_PATH")
    if env:
        return env
    home_db = Path.home() / ".agent-harness" / "db" / "agent.db"
    if home_db.exists():
        return str(home_db)
    return str(Path(__file__).resolve().parent / "db" / "agent.db")

DB_PATH = _resolve_db_path()

# ── DB 工具 ───────────────────────────────────────────────

def get_connection():
    """取得 SQLite 連線，DB 不存在時回傳 None。"""
    if not Path(DB_PATH).exists():
        return None
    conn = sqlite3.connect(DB_PATH, timeout=5)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA foreign_keys=ON")
    return conn


def safe_query(conn, sql, params=()):
    """安全查詢，忽略 table 不存在等錯誤。"""
    try:
        return conn.execute(sql, params).fetchall()
    except (sqlite3.OperationalError, sqlite3.DatabaseError):
        return []


def safe_query_one(conn, sql, params=()):
    try:
        return conn.execute(sql, params).fetchone()
    except (sqlite3.OperationalError, sqlite3.DatabaseError):
        return None


def row_to_dict(row):
    """將 sqlite3.Row 轉換為 dict。"""
    if row is None:
        return None
    return dict(row)


def rows_to_list(rows):
    """將 sqlite3.Row list 轉換為 dict list。"""
    return [dict(r) for r in rows]


def parse_json_field(value):
    """嘗試將 JSON 字串 parse 成 Python 物件，失敗時回傳原值。"""
    if value is None:
        return None
    try:
        return json.loads(value)
    except (json.JSONDecodeError, TypeError):
        return value


# ── API 處理 ─────────────────────────────────────────────

def handle_stats():
    """GET /api/stats"""
    conn = get_connection()
    if conn is None:
        return {"counts": {}, "pass_rate": 0, "total_runs": 0, "total_duration": 0}

    try:
        # 各 status 的任務數量
        counts = {}
        for status in ("pending", "running", "pass", "fail", "escalated", "skipped", "blocked"):
            r = safe_query_one(conn, "SELECT COUNT(*) AS cnt FROM tasks WHERE status = ?", (status,))
            counts[status] = r["cnt"] if r else 0

        # runs 統計
        stats = safe_query_one(conn, """
            SELECT
                COUNT(*) AS total_runs,
                SUM(CASE WHEN status = 'pass' THEN 1 ELSE 0 END) AS pass_count,
                SUM(CASE WHEN status IN ('pass', 'fail', 'error') THEN 1 ELSE 0 END) AS completed,
                COALESCE(SUM(duration_sec), 0) AS total_duration
            FROM runs
        """)

        total_runs = 0
        pass_rate = 0
        total_duration = 0
        if stats:
            total_runs = stats["total_runs"] or 0
            completed = stats["completed"] or 0
            pass_count = stats["pass_count"] or 0
            pass_rate = round(pass_count / completed * 100, 1) if completed > 0 else 0
            total_duration = stats["total_duration"] or 0

        return {
            "counts": counts,
            "pass_rate": pass_rate,
            "total_runs": total_runs,
            "total_duration": total_duration,
        }
    finally:
        conn.close()


def handle_tasks(query_params):
    """GET /api/tasks"""
    conn = get_connection()
    if conn is None:
        return []

    try:
        sql = "SELECT * FROM tasks WHERE 1=1"
        params = []

        project = query_params.get("project", [None])[0]
        if project:
            sql += " AND project = ?"
            params.append(project)

        status = query_params.get("status", [None])[0]
        if status:
            sql += " AND status = ?"
            params.append(status)

        role = query_params.get("role", [None])[0]
        if role:
            sql += " AND role = ?"
            params.append(role)

        sql += " ORDER BY created_at DESC"
        rows = safe_query(conn, sql, params)

        result = []
        for r in rows:
            d = dict(r)
            d["depends_on"] = parse_json_field(d.get("depends_on"))
            d["touches"] = parse_json_field(d.get("touches"))
            result.append(d)
        return result
    finally:
        conn.close()


def handle_task_detail(task_id):
    """GET /api/tasks/<id>"""
    conn = get_connection()
    if conn is None:
        return None

    try:
        row = safe_query_one(conn, "SELECT * FROM tasks WHERE id = ?", (task_id,))
        if row is None:
            return None
        d = dict(row)
        d["depends_on"] = parse_json_field(d.get("depends_on"))
        d["touches"] = parse_json_field(d.get("touches"))
        return d
    finally:
        conn.close()


def handle_task_runs(task_id):
    """GET /api/tasks/<id>/runs"""
    conn = get_connection()
    if conn is None:
        return []

    try:
        rows = safe_query(conn, """
            SELECT id, attempt, status, worker_id, prompt_text, claude_output,
                   verify_output, error_class, duration_sec, started_at, finished_at,
                   output_fingerprint, input_prompt_hash
            FROM runs
            WHERE task_id = ?
            ORDER BY attempt ASC
        """, (task_id,))
        return rows_to_list(rows)
    finally:
        conn.close()


def handle_graph():
    """GET /api/graph — 任務關係圖（spawned_by + depends_on）。"""
    conn = get_connection()
    if conn is None:
        return {"nodes": [], "edges": []}

    try:
        all_tasks = safe_query(conn, """
            SELECT id, project, goal, status, role, spawned_by, depends_on
            FROM tasks
        """)

        if not all_tasks:
            return {"nodes": [], "edges": []}

        node_map = {}
        edges = []

        # 收集所有有關係的任務 ID
        related_ids = set()
        for t in all_tasks:
            has_relation = False
            # spawned_by 關係
            if t["spawned_by"]:
                related_ids.add(t["id"])
                related_ids.add(t["spawned_by"])
                edges.append({"from": t["spawned_by"], "to": t["id"], "type": "spawned"})
                has_relation = True
            # depends_on 關係
            deps = parse_json_field(t["depends_on"])
            if deps:
                related_ids.add(t["id"])
                for dep_id in deps:
                    related_ids.add(dep_id)
                    edges.append({"from": dep_id, "to": t["id"], "type": "depends"})
                has_relation = True

        # 建立 node 清單（只包含有關係的任務）
        for t in all_tasks:
            if t["id"] in related_ids:
                node_map[t["id"]] = {
                    "id": t["id"],
                    "project": t["project"],
                    "goal": t["goal"],
                    "status": t["status"],
                    "role": t["role"],
                }

        return {"nodes": list(node_map.values()), "edges": edges}
    finally:
        conn.close()


def handle_audit(query_params):
    """GET /api/audit"""
    conn = get_connection()
    if conn is None:
        return []

    try:
        sql = "SELECT * FROM audit_log WHERE 1=1"
        params = []

        task_id = query_params.get("task_id", [None])[0]
        if task_id:
            sql += " AND task_id = ?"
            params.append(task_id)

        event_type = query_params.get("event_type", [None])[0]
        if event_type:
            sql += " AND event_type = ?"
            params.append(event_type)

        sql += " ORDER BY created_at DESC"
        rows = safe_query(conn, sql, params)

        result = []
        for r in rows:
            d = dict(r)
            d["event_data"] = parse_json_field(d.get("event_data"))
            result.append(d)
        return result
    finally:
        conn.close()


def handle_pipelines():
    """GET /api/pipelines"""
    conn = get_connection()
