# ── URL Routing ──────────────────────────────────────────

ROUTES = [
    (re.compile(r"^/api/stats$"), "GET", handle_stats),
    (re.compile(r"^/api/tasks$"), "GET", handle_tasks),
    (re.compile(r"^/api/tasks/([^/]+)/runs$"), "GET", handle_task_runs),
    (re.compile(r"^/api/tasks/([^/]+)$"), "GET", handle_task_detail),
    (re.compile(r"^/api/graph$"), "GET", handle_graph),
    (re.compile(r"^/api/audit$"), "GET", handle_audit),
    (re.compile(r"^/api/pipelines$"), "GET", handle_pipelines),
    (re.compile(r"^/api/router-decisions$"), "GET", handle_router_decisions),
]


# ── HTTP Handler ─────────────────────────────────────────

class APIHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path
        query_params = parse_qs(parsed.query)

        # 根路徑回傳內嵌儀表板 HTML
        if path == "/" or path == "":
            self._send_html(DASHBOARD_HTML)
            return

        for pattern, method, handler in ROUTES:
            match = pattern.match(path)
            if match and method == "GET":
                try:
                    groups = match.groups()
                    # 根據 handler 參數數量決定如何呼叫
                    if groups and handler in (handle_task_detail, handle_task_runs):
                        result = handler(groups[0])
                    elif handler in (handle_tasks, handle_audit):
                        result = handler(query_params)
                    else:
                        result = handler()

                    if result is None:
                        self._send_json({"error": "not found"}, 404)
                    else:
                        self._send_json(result)
                except Exception as e:
                    self._send_json({"error": str(e)}, 500)
                return

        self._send_json({"error": "not found"}, 404)

    def do_OPTIONS(self):
        """處理 CORS preflight 請求。"""
        self.send_response(200)
        self._set_cors_headers()
        self.end_headers()

    def _send_json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False, default=str).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self._set_cors_headers()
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _send_html(self, html, status=200):
        body = html.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self._set_cors_headers()
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _set_cors_headers(self):
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")

    def log_message(self, format, *args):
        """覆寫預設 log，加上時間戳。"""
        sys.stderr.write(f"[{time.strftime('%H:%M:%S')}] {args[0]}\n")


# ── 自我測試 ─────────────────────────────────────────────

def run_self_check(port):
    """啟動 server 在背景線程，打幾個 API 確認回傳格式，然後退出。"""
    from urllib.request import urlopen
    from urllib.error import URLError

    server = HTTPServer(("127.0.0.1", port), APIHandler)
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    # 等待 server 就緒
    time.sleep(0.3)

    # 測試 GET / 回傳 HTML 儀表板
    all_ok = True
    try:
        resp = urlopen(f"http://127.0.0.1:{port}/", timeout=5)
        if resp.status != 200:
            print(f"FAIL /: HTTP {resp.status}")
            all_ok = False
        else:
            body = resp.read().decode("utf-8")
            content_type = resp.headers.get("Content-Type", "")
            if "text/html" not in content_type:
                print(f"FAIL /: Content-Type = {content_type}")
                all_ok = False
            elif "<!DOCTYPE html>" not in body:
                print(f"FAIL /: HTML 內容不完整")
                all_ok = False
            else:
                print(f"  OK / → HTML ({len(body)} bytes)")
    except (URLError, Exception) as e:
        print(f"FAIL /: {e}")
        all_ok = False

    # 測試 JSON API 端點
    endpoints = [
        "/api/stats",
        "/api/tasks",
        "/api/graph",
        "/api/audit",
        "/api/pipelines",
        "/api/router-decisions",
    ]

    for ep in endpoints:
        url = f"http://127.0.0.1:{port}{ep}"
        try:
            resp = urlopen(url, timeout=5)
            if resp.status != 200:
                print(f"FAIL {ep}: HTTP {resp.status}")
                all_ok = False
                continue

            body = resp.read().decode("utf-8")
            data = json.loads(body)

            content_type = resp.headers.get("Content-Type", "")
            if "application/json" not in content_type:
                print(f"FAIL {ep}: Content-Type = {content_type}")
                all_ok = False
                continue

            cors = resp.headers.get("Access-Control-Allow-Origin", "")
            if cors != "*":
                print(f"FAIL {ep}: CORS header missing")
                all_ok = False
                continue

            print(f"  OK {ep} → {type(data).__name__}")
        except (URLError, json.JSONDecodeError, Exception) as e:
            print(f"FAIL {ep}: {e}")
            all_ok = False

    server.shutdown()

    if all_ok:
        print("\n自我測試通過 ✓")
        sys.exit(0)
    else:
        print("\n自我測試失敗 ✗")
        sys.exit(1)


# ── 主程式 ────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="web-dashboard",
        description="Agent Harness REST API server — 提供 JSON API 供前端儀表板使用",
    )
    parser.add_argument("--port", type=int, default=8745, help="監聽 port（預設 8745）")
    parser.add_argument("--check", action="store_true", help="自我測試模式：啟動 server → 驗證 API → 退出")
    args = parser.parse_args()

    if args.check:
        print(f"自我測試模式：port {args.port}")
        run_self_check(args.port)
        return

    server = HTTPServer(("0.0.0.0", args.port), APIHandler)
    print(f"Web Dashboard 啟動於 http://localhost:{args.port}")
    print(f"儀表板：http://localhost:{args.port}/")
    print(f"DB 路徑：{DB_PATH}")
    print("按 Ctrl+C 停止")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nServer 已停止。")
        server.shutdown()


if __name__ == "__main__":
    main()
